'Const timeserv = "0.pool.ntp.org"

Const heating_rh = 80 ' Switch on sensor heating above this relative humidity value
Const heating_t = 2 ' Switch on sensor heating below this air temperature value

Const IR20_1_a = -15.1993*10^-6 ' temperature correction parameter degC-2
Const IR20_1_b = 26.7575*10^-4 ' temperature correction parameter degC
Const IR20_1_c = 0.9526' temperature correction parameter
Const IR20_1_S0 = 11.55*10^-6 ' sensitivity V W-1 m2

Const IR20_2_a = -15.6504*10^-6 ' temperature correction parameter
Const IR20_2_b = 27.5429*10^-4 ' temperature correction parameter
Const IR20_2_c = 0.9512 ' temperature correction parameter
Const IR20_2_S0 = 12.22*10^-6' sensitivity



